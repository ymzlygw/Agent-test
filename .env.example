# ─── Cursor API ────────────────────────────────────────────────────────────────
# Cursor API 密钥，用于调用 Cursor Agent
CURSOR_API_KEY=your_cursor_api_key_here

# ─── GitHub ────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token（需要 repo 权限，用于读取 PR diff 和发布评论）
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub Webhook Secret（在 GitHub 仓库 Settings > Webhooks 中配置的密钥，建议设置）
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─── ngrok（内网穿透）──────────────────────────────────────────────────────────
# ngrok 认证 Token（从 https://dashboard.ngrok.com/get-started/your-authtoken 获取）
NGROK_TOKEN=your_ngrok_authtoken_here

# ngrok 自定义域名（可选，仅 ngrok 付费计划支持固定域名）
# 示例: your-custom-domain.ngrok-free.app
NGROK_DOMAIN=

# ─── 服务配置 ──────────────────────────────────────────────────────────────────
# 服务监听端口（默认 7860）
PORT=7860
